{
	"Colors": {
		// 选择区域代码
		"__DEFAULT_FRONTGROUND": [0, 0, 0],				// 默认文本颜色
		"__DEFAULT_BACKGROUND": [255, 255, 255],		// 默认背景颜色
		"__SELECT_FRONTGROUND": [255, 255, 255],		// 选中前景颜色
		"__SELECT_BACKGROUND": [0, 128, 255],			// 选中背景颜色
		"__LINE_COLOR": [128, 128, 128],				// 流程线颜色
		
		// 代码颜色定义
		"__CODE": [
			{
				"type": 1,
				"name": "流程控制",
				"en_name": "ELCODE_TYPE_CONTROL",
				"color": [0, 0, 255]
			},
			{
				"type": 2,
				"name": "操作符",
				"en_name": "ELCODE_TYPE_OPERATOR",
				"color": [0, 0, 128]
			},
			{
				"type": 10,
				"name": "符号",
				"en_name": "ELCODE_TYPE_SYMBOL",
				"color": [0, 0, 128]
			},
			{
				"type": 11,
				"name": "起始符",
				"en_name": "ELCODE_TYPE_SYMBOL_BEGIN",
				"color": [0, 0, 128]
			},
			{
				"type": 12,
				"name": "结束符",
				"en_name": "ELCODE_TYPE_SYMBOL_END",
