    "Templates": {
        // 基础(所有模板的父样式)
        "__BASE": {
            "margin": 0,
            "padding": [6, 5],
            "color": "__DEFAULT_FRONTGROUND",
			"border": {
				"wide":	0,
				"circle": 0,
				"color": [128, 128, 128]
			},
            "background": "__DEFAULT_BACKGROUND",
			"font": {
				"name":		"宋体",								// 字体名称
				"size":		12,									// 字体宽度
				"bold":		false,								// 是否粗体
				"italic":	false,								// 是否斜体
				"underline": false,								// 是否下划线
				"strikeout": false,								// 是否中划线
				"blank":	0									// 空白
			}
        },
        // 代码段
        "__SECTION": {
            "margin": [8, 4, 4, 8],
            "padding": 0
        },
        // 代码行
        "__CODE": {
            "margin": [2, 0, 2, 4],
            "padding": 0
        },
        // 单元格
        "__COLUMN": {
			"border": {
				"wide":	1,
				"circle": 0,
				"color": [128, 128, 128]
			},
            "padding": 6
        },
        // 表格
        "__TABLE": {
            "margin": 6,
            "padding": 0,
			"border": {
				"wide":	0,
				"circle": 0,
				"color": [128, 128, 128]
			},
			"background": [128, 128, 128]
        },
        // 公共_表格_标题
        "NL_GLOBAL_TABLE_TITLE": {
			"__PARENT": "__COLUMN",
            "color": [0, 0, 128]
        },
        // 公共_表格_变量标题
        "NL_GLOBAL_TABLE_VAR_TITLE": {
			"__PARENT": "__COLUMN",
            "color": [0, 0, 128]
        },
        // 公共_表格_普通
        "NL_GLOBAL_TABLE_TEXT": {
			"__PARENT": "__COLUMN",
            "color": [0, 0, 0]
        },
        // 公共_表格_类型
        "NL_GLOBAL_TABLE_TYPE": {
			"__PARENT": "__COLUMN",
            "color": [0, 0, 255]
        },
        // 公共_表格_注释
        "NL_GLOBAL_TABLE_DESC": {
			"__PARENT": "__COLUMN",
            "color": [0, 128, 0]
        },
        // 公共_表格_数组
        "NL_GLOBAL_TABLE_ARRAY": {
			"__PARENT": "__COLUMN",
            "color": [0, 0, 128]
        },
        // 公共_表格_复选
        "NL_GLOBAL_TABLE_CHECK": {
			"__PARENT": "__COLUMN",
            "color": [128, 0, 0],
            "align": 1,
            "valign": 1
        },

        // 程序集_表格标题
        "NL_FORMFUNC_TABLE_TITLE": {
			"__PARENT": "__COLUMN",
            "color": [0, 0, 0],
            "background": [236, 236, 236]
        },
        // 函数_表格标题
        "NL_FUNC_TABLE_TITLE": {
			"__PARENT": "__COLUMN",
            "color": [0, 0, 0],
            "background": [230, 237, 228]
        },
        // 局部变量_表格标题
        "NL_LOCALVAR_TABLE_TITLE": {
			"__PARENT": "__COLUMN",
            "color": [0, 0, 0],
            "background": [217, 227, 240]
        },
		
        // 表格：局部变量
        "LocalVar": {
			"__PARENT": "__TABLE",
            "margin": [6, 0, 6, 6]
        }
    }
}