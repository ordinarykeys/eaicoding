				"en_name": "ELCODE_TYPE_DOUBLE",
				"color": [128, 0, 0]
			},
			{
				"type": 7,
				"name": "文本",
				"en_name": "ELCODE_TYPE_STRING",
				"color": [0, 128, 128]
			},
			{
				"type": 8,
				"name": "字节集",
				"en_name": "ELCODE_TYPE_BINARY",
